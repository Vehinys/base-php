<!DOCTYPE html>
<html lang="{{ app.request.locale|slice(0,2) }}" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'app.name'|trans }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ 'app.description'|trans }}{% endblock %}">
    <meta name="robots" content="{% block robots %}index,follow{% endblock %}">
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap"></noscript>

    <meta property="og:title" content="{% block og_title %}{{ 'app.name'|trans }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ 'app.description'|trans }}{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('favicon.svg')) }}{% endblock %}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    {# canonical sans query string — évite le duplicate content pour les URLs paginées #}
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

</head>
<body class="min-h-screen flex flex-col" style="background-color:var(--color-bg);color:var(--color-text)">

    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 btn-primary"
       style="font-size:0.875rem">
        {{ 'nav.skip_to_content'|trans }}
    </a>

    {# ═══════════════════════════════════════════════════════ HEADER #}
    <header role="banner"
            style="background:rgba(15,15,29,0.82);border-bottom:1px solid rgba(124,106,247,0.12);position:sticky;top:0;z-index:40;backdrop-filter:blur(20px) saturate(160%);-webkit-backdrop-filter:blur(20px) saturate(160%)">
        <nav role="navigation"
             aria-label="{{ 'nav.main'|trans }}"
             class="max-w-6xl mx-auto px-6"
             style="height:64px;display:flex;align-items:center;justify-content:space-between;gap:1.5rem">

            {# Logo #}
            <a href="{{ path('app_home') }}"
               aria-label="{{ 'app.name'|trans }} — {{ 'nav.home'|trans }}"
               style="font-family:var(--font-display);font-size:1.25rem;font-weight:800;color:var(--color-primary);text-decoration:none;flex-shrink:0;display:flex;align-items:center;gap:0.5rem">
                <span aria-hidden="true" style="font-size:1.5rem">&#9679;</span>
                {{ 'app.name'|trans }}
            </a>

            {# Nav desktop #}
            <div class="nav-desktop" style="display:flex;align-items:center;gap:1.5rem;flex:1">
                <a href="{{ path('app_home') }}"
                   style="font-size:0.9375rem;font-weight:500;color:{% if app.request.attributes.get('_route') == 'app_home' %}var(--color-text){% else %}var(--color-muted){% endif %};text-decoration:none;transition:color 0.15s"
                   {% if app.request.attributes.get('_route') == 'app_home' %}aria-current="page"{% endif %}>
                    {{ 'nav.home'|trans }}
                </a>
                {% block nav_items %}{% endblock %}
            </div>

            {# Actions desktop #}
            <div class="nav-desktop" style="display:flex;align-items:center;gap:1rem">

                {# Sélecteur de langue #}
                <div role="group" aria-label="{{ 'nav.language'|trans }}"
                     style="display:flex;align-items:center;gap:2px;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:0.375rem;padding:2px">
                    <a href="{{ path('app_locale', {locale: 'fr'}) }}"
                       hreflang="fr"
                       aria-label="Français"
                       {% if app.request.locale starts with 'fr' %}aria-pressed="true"{% endif %}
                       style="padding:0.25rem 0.5rem;border-radius:0.25rem;font-size:0.75rem;font-weight:600;text-decoration:none;transition:all 0.15s;
                              {% if app.request.locale starts with 'fr' %}background:var(--color-primary);color:#fff{% else %}color:var(--color-muted){% endif %}">
                        FR
                    </a>
                    <a href="{{ path('app_locale', {locale: 'en'}) }}"
                       hreflang="en"
                       aria-label="English"
                       {% if app.request.locale starts with 'en' %}aria-pressed="true"{% endif %}
                       style="padding:0.25rem 0.5rem;border-radius:0.25rem;font-size:0.75rem;font-weight:600;text-decoration:none;transition:all 0.15s;
                              {% if app.request.locale starts with 'en' %}background:var(--color-primary);color:#fff{% else %}color:var(--color-muted){% endif %}">
                        EN
                    </a>
                </div>

                {# Auth #}
                {% if app.user %}
                    <div class="user-dropdown" id="userDropdown">
                        <button onclick="document.getElementById('userDropdown').classList.toggle('open')"
                                aria-haspopup="true"
                                aria-expanded="false"
                                aria-label="{{ 'nav.user_menu'|trans }}"
                                style="display:flex;align-items:center;gap:0.5rem;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:0.5rem;padding:0.375rem 0.75rem;cursor:pointer;color:var(--color-text);font-size:0.875rem;font-weight:500">
                            {% if app.user.avatarUrl %}
                                <img src="{{ app.user.avatarUrl }}"
                                     alt="{{ app.user.name ?? app.user.email }}"
                                     width="24" height="24"
                                     style="border-radius:50%;object-fit:cover">
                            {% else %}
                                <span aria-hidden="true"
                                      style="width:24px;height:24px;border-radius:50%;background:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#fff">
                                    {{ (app.user.name ?? app.user.email)|slice(0,1)|upper }}
                                </span>
                            {% endif %}
                            <span style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                {{ app.user.name ?? app.user.email }}
                            </span>
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 4l4 4 4-4"/>
                            </svg>
                        </button>
                        <div class="user-dropdown-panel" role="menu">
                            {# POST obligatoire pour le logout — CSRF requis via security.yaml #}
                            <form method="post" action="{{ path('app_logout') }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit" class="dropdown-item" role="menuitem">
                                    {{ 'nav.logout'|trans }}
                                </button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <a href="{{ path('app_login') }}"
                       style="font-size:0.875rem;font-weight:500;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                       onmouseover="this.style.color='var(--color-text)'"
                       onmouseout="this.style.color='var(--color-muted)'">
                        {{ 'nav.login'|trans }}
                    </a>
                    <a href="{{ path('app_register') }}" class="btn-primary" style="font-size:0.875rem">
                        {{ 'nav.register'|trans }}
                    </a>
                {% endif %}
            </div>

            {# Hamburger mobile #}
            <button class="nav-hamburger"
                    id="mobileMenuBtn"
                    aria-controls="mobileMenu"
                    aria-expanded="false"
                    aria-label="{{ 'nav.open_menu'|trans }}"
                    data-label-open="{{ 'nav.open_menu'|trans }}"
                    data-label-close="{{ 'nav.close_menu'|trans }}"
                    style="display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px">
                <span style="display:block;width:22px;height:2px;background:var(--color-text);border-radius:2px;transition:transform 0.2s"></span>
                <span style="display:block;width:22px;height:2px;background:var(--color-text);border-radius:2px;transition:opacity 0.2s"></span>
                <span style="display:block;width:22px;height:2px;background:var(--color-text);border-radius:2px;transition:transform 0.2s"></span>
            </button>
        </nav>

        {# Menu mobile #}
        <div id="mobileMenu"
             class="nav-mobile-menu"
             style="flex-direction:column;gap:0;background:var(--color-surface);border-top:1px solid var(--color-border);padding:1rem 1.5rem 1.5rem">
            <a href="{{ path('app_home') }}"
               style="padding:0.625rem 0;font-size:0.9375rem;font-weight:500;color:var(--color-muted);text-decoration:none;border-bottom:1px solid var(--color-border)">
                {{ 'nav.home'|trans }}
            </a>
            {% if app.user %}
                <span style="padding:0.625rem 0;font-size:0.875rem;color:var(--color-muted);border-bottom:1px solid var(--color-border)">
                    {{ app.user.name ?? app.user.email }}
                </span>
                <form method="post" action="{{ path('app_logout') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit"
                            style="padding:0.625rem 0;font-size:0.875rem;color:var(--color-muted);background:none;border:none;cursor:pointer;width:100%;text-align:left">
                        {{ 'nav.logout'|trans }}
                    </button>
                </form>
            {% else %}
                <a href="{{ path('app_login') }}"
                   style="padding:0.625rem 0;font-size:0.9375rem;color:var(--color-muted);text-decoration:none;border-bottom:1px solid var(--color-border)">
                    {{ 'nav.login'|trans }}
                </a>
                <a href="{{ path('app_register') }}"
                   style="padding:0.625rem 0;font-size:0.9375rem;font-weight:600;color:var(--color-primary);text-decoration:none">
                    {{ 'nav.register'|trans }}
                </a>
            {% endif %}
            <div style="display:flex;gap:0.5rem;padding-top:1rem">
                <a href="{{ path('app_locale', {locale: 'fr'}) }}" hreflang="fr"
                   style="font-size:0.8125rem;font-weight:600;padding:0.25rem 0.625rem;border-radius:0.25rem;text-decoration:none;
                          {% if app.request.locale starts with 'fr' %}background:var(--color-primary);color:#fff{% else %}color:var(--color-muted);background:var(--color-surface-2){% endif %}">
                    Français
                </a>
                <a href="{{ path('app_locale', {locale: 'en'}) }}" hreflang="en"
                   style="font-size:0.8125rem;font-weight:600;padding:0.25rem 0.625rem;border-radius:0.25rem;text-decoration:none;
                          {% if app.request.locale starts with 'en' %}background:var(--color-primary);color:#fff{% else %}color:var(--color-muted);background:var(--color-surface-2){% endif %}">
                    English
                </a>
            </div>
        </div>
    </header>

    {# ═══════════════════════════════════════════════════════ CONTENU #}
    <main id="main-content" role="main" class="flex-1">
        {% block body %}{% endblock %}
    </main>

    {# ═══════════════════════════════════════════════════════ FOOTER #}
    <footer role="contentinfo"
            style="background-color:var(--color-surface);border-top:1px solid var(--color-border);margin-top:auto">

        {# Bloc principal #}
        <div class="max-w-6xl mx-auto px-6 py-12 footer-grid"
             style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem">

            {# Colonne 1 — Marque #}
            <div>
                <a href="{{ path('app_home') }}"
                   style="font-family:var(--font-display);font-size:1.25rem;font-weight:800;color:var(--color-primary);text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem">
                    <span aria-hidden="true">&#9679;</span>
                    {{ 'app.name'|trans }}
                </a>
                <p style="font-size:0.875rem;color:var(--color-muted);line-height:1.6;max-width:260px;margin-top:0.5rem">
                    {{ 'footer.tagline'|trans }}
                </p>
                <div style="display:flex;gap:0.75rem;margin-top:1.25rem">
                    <a href="https://github.com/Vehinys/base-php"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="GitHub"
                       style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:0.5rem;border:1px solid var(--color-border);color:var(--color-muted);transition:color 0.15s,border-color 0.15s;text-decoration:none"
                       onmouseover="this.style.color='var(--color-text)';this.style.borderColor='var(--color-primary)'"
                       onmouseout="this.style.color='var(--color-muted)';this.style.borderColor='var(--color-border)'">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                        </svg>
                    </a>
                </div>
            </div>

            {# Colonne 2 — Navigation #}
            <nav aria-label="{{ 'footer.nav_title'|trans }}">
                {# aria-hidden : le nav a déjà un aria-label identique — évite la redondance pour les lecteurs d'écran #}
                <p style="font-family:var(--font-display);font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text);margin-bottom:1rem" aria-hidden="true">
                    {{ 'footer.nav_title'|trans }}
                </p>
                <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem">
                    <li>
                        <a href="{{ path('app_home') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'nav.home'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_login') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'nav.login'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_register') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'nav.register'|trans }}
                        </a>
                    </li>
                </ul>
            </nav>

            {# Colonne 3 — Légal #}
            <nav aria-label="{{ 'footer.legal_title'|trans }}">
                <p style="font-family:var(--font-display);font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text);margin-bottom:1rem" aria-hidden="true">
                    {{ 'footer.legal_title'|trans }}
                </p>
                <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem">
                    <li>
                        <a href="{{ path('legal_mentions') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'footer.legal_mentions'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('legal_privacy') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'footer.legal_privacy'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('legal_cgu') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'footer.legal_cgu'|trans }}
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('legal_cookies') }}"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            {{ 'footer.legal_cookies'|trans }}
                        </a>
                    </li>
                </ul>
            </nav>

            {# Colonne 4 — Contact #}
            <div>
                <p style="font-family:var(--font-display);font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text);margin-bottom:1rem">
                    {{ 'footer.contact_title'|trans }}
                </p>
                <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem">
                    <li>
                        <a href="mailto:contact@baseapp.dev"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s;display:flex;align-items:center;gap:0.375rem"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            contact@baseapp.dev
                        </a>
                    </li>
                    <li>
                        <a href="https://github.com/Vehinys/base-php"
                           target="_blank"
                           rel="noopener noreferrer"
                           style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.15s;display:flex;align-items:center;gap:0.375rem"
                           onmouseover="this.style.color='var(--color-text)'"
                           onmouseout="this.style.color='var(--color-muted)'">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                            </svg>
                            GitHub
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        {# Barre de bas de page #}
        <div style="border-top:1px solid var(--color-border)">
            <div class="max-w-6xl mx-auto px-6 py-4"
                 style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem">
                <p style="font-size:0.8125rem;color:var(--color-muted);margin:0">
                    &copy; {{ "now"|date("Y") }} <strong style="color:var(--color-text)">{{ 'app.name'|trans }}</strong>.
                    {{ 'footer.all_rights'|trans }}
                </p>
                <p style="font-size:0.8125rem;color:var(--color-muted);margin:0">
                    {{ 'footer.built_with'|trans }}
                </p>
            </div>
        </div>
    </footer>

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

    {# Logique menu mobile et dropdown déplacée dans assets/app.js (compilé par Webpack Encore) #}
</body>
</html>
