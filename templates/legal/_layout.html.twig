{#
    Layout partagé pour toutes les pages légales (mentions, RGPD, CGU, cookies).

    Structure :
      - Sidebar sticky (240px) avec navigation entre les 4 documents
      - Article principal (flex:1) avec le contenu injecté via {% block legal_content %}
      - CSS local (.legal-content) pour la typographie éditoriale des documents légaux

    Navigation sidebar :
      La liste legal_links est définie dans ce template pour centraliser les routes
      et labels en un seul endroit (DRY). aria-current="page" indique la page active
      aux lecteurs d'écran et permet le ciblage CSS de l'élément actif.

    Position sticky de la sidebar :
      top:88px = hauteur du header (64px) + marge de 24px.
      En mobile (max-width:768px), la sidebar passe en position:static via le CSS local.

    Surcharge de ce layout :
      Les templates enfants (mentions.html.twig, privacy.html.twig…) héritent de ce layout
      via {% extends 'legal/_layout.html.twig' %} et définissent {% block legal_content %}.
#}
{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-6xl mx-auto px-6 py-16" style="display:grid;grid-template-columns:240px 1fr;gap:3rem;align-items:start">

    {#
        Sidebar sticky — liste des documents légaux avec highlighting de la page active.
        position:sticky + top:88px = reste visible pendant le scroll vertical du contenu.
    #}
    <aside aria-label="{{ 'legal.nav_title'|trans }}"
           style="position:sticky;top:88px">
        <p style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-muted);margin-bottom:0.75rem;font-family:var(--font-display)">
            {{ 'legal.nav_title'|trans }}
        </p>
        <nav>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:2px">
                {# Centralisation des liens légaux — évite de dupliquer dans chaque template enfant #}
                {% set legal_links = [
                    {route: 'legal_mentions',  label: 'footer.legal_mentions'},
                    {route: 'legal_privacy',   label: 'footer.legal_privacy'},
                    {route: 'legal_cgu',       label: 'footer.legal_cgu'},
                    {route: 'legal_cookies',   label: 'footer.legal_cookies'},
                ] %}
                {% for item in legal_links %}
                <li>
                    <a href="{{ path(item.route) }}"
                       {% if app.request.attributes.get('_route') == item.route %}aria-current="page"{% endif %}
                       style="display:block;padding:0.5rem 0.75rem;border-radius:0.375rem;font-size:0.875rem;text-decoration:none;transition:background 0.15s,color 0.15s;
                              {% if app.request.attributes.get('_route') == item.route %}
                                  background:color-mix(in srgb,var(--color-primary) 15%,transparent);
                                  color:var(--color-primary);font-weight:600;
                              {% else %}
                                  color:var(--color-muted);
                              {% endif %}">
                        {{ item.label|trans }}
                    </a>
                </li>
                {% endfor %}
            </ul>
        </nav>

        {# Encart "Dernière mise à jour" — date définie dans les fichiers de traduction #}
        <div style="margin-top:1.5rem;padding:0.875rem;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:0.5rem">
            <p style="font-size:0.8125rem;color:var(--color-muted);margin:0 0 0.5rem">
                {{ 'legal.last_updated'|trans }}
            </p>
            <p style="font-size:0.875rem;font-weight:600;color:var(--color-text);margin:0">
                {{ 'legal.last_updated_date'|trans }}
            </p>
        </div>
    </aside>

    {# Contenu légal — injecté par le template enfant via {% block legal_content %} #}
    <article class="legal-content" style="min-width:0">
        {% block legal_content %}{% endblock %}
    </article>
</div>

{#
    CSS local pour la typographie des documents légaux.
    Défini ici plutôt que dans app.css car il ne s'applique qu'aux pages légales.
    Les sélecteurs h1/h2/h3/p/ul/li ciblent le contenu brut des templates enfants
    sans nécessiter de classes CSS sur chaque élément.
#}
<style>
.legal-content h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.5rem;
}
.legal-content .subtitle {
    color: var(--color-muted);
    font-size: 0.9375rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
}
.legal-content h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 2.5rem 0 0.875rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 88px; /* compense le header sticky pour le scroll sur ancre #id */
}
.legal-content h2:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
.legal-content h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 1.5rem 0 0.5rem;
}
.legal-content p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin: 0 0 1rem;
}
.legal-content ul, .legal-content ol {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
}
.legal-content li {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: 0.25rem;
}
.legal-content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
}
.legal-content strong {
    color: var(--color-text);
    font-weight: 600;
}
.legal-content .info-box {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
}
.legal-content .info-box p { margin: 0; color: var(--color-text); }
/* Mobile : sidebar passe en bloc au-dessus du contenu */
@media (max-width: 768px) {
    .max-w-6xl [style*="grid-template-columns: 240px"] {
        grid-template-columns: 1fr !important;
    }
    aside[style*="position:sticky"] {
        position: static !important;
    }
}
</style>
{% endblock %}
