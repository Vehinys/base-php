{#
    Page d'accueil — vitrine du starter Symfony.

    Sections :
      1. Hero — titre accrocheur, sous-titre, CTA adaptatif (connecté vs anonyme)
      2. Features — 3 cartes présentant les fonctionnalités principales du starter

    CTA adaptatif :
      Si l'utilisateur est connecté (app.user), un CTA personnalisé avec son nom est affiché.
      Sinon, les boutons "Créer un compte" et "Se connecter" sont proposés.

    Décoration géométrique :
      Tout le bloc <div aria-hidden="true"> est masqué aux lecteurs d'écran.
      SVG inline préférés à des images pour le contrôle du thème (stroke="var(--color-muted)").

    Animations CSS (fadeIn, fadeUp) :
      Définies dans app.css avec @keyframes. opacity:0 en style inline + animation fill-mode:both
      garantit que les éléments sont invisibles avant le début de l'animation,
      évitant un flash de contenu non animé (FOCA).

    JSON-LD Schema.org WebSite :
      Aide les moteurs de recherche à comprendre le contexte du site.
      escape('js') évite l'injection dans le JSON si les traductions contiennent des guillemets.

    h2.sr-only Features :
      La section des fonctionnalités a un h2 visible uniquement pour les lecteurs d'écran
      (aria-labelledby="features-heading"). La grille visuelle est auto-explicite pour
      les utilisateurs voyants, mais la hiérarchie de titres doit rester cohérente.
#}
{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }} — {{ 'app.name'|trans }}{% endblock %}

{% block body %}

{# ═══════════════════════════════════════════════════════ HERO #}
<section class="hero-section" aria-labelledby="hero-heading">

    {# Décoration géométrique — grille fine + formes SVG, pas d'orbes flous #}
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden">

        {# Grille de fond (effet blueprint) #}
        <div style="position:absolute;inset:0;
                    background-image:linear-gradient(var(--color-border) 1px,transparent 1px),
                                     linear-gradient(90deg,var(--color-border) 1px,transparent 1px);
                    background-size:56px 56px;
                    opacity:0.6;
                    mask-image:radial-gradient(ellipse 80% 90% at 50% 50%,black 20%,transparent 100%)"></div>

        {# Cercle géométrique décoratif à droite #}
        <svg style="position:absolute;right:-4%;top:50%;transform:translateY(-50%);
                    width:clamp(180px,36vw,520px);height:clamp(180px,36vw,520px);opacity:0.06"
             viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="96" stroke="var(--color-text)" stroke-width="1"/>
            <circle cx="100" cy="100" r="60" stroke="var(--color-primary)" stroke-width="0.8" stroke-dasharray="5 5"/>
            <circle cx="100" cy="100" r="3" fill="var(--color-primary)" opacity="1"/>
            <line x1="0" y1="100" x2="200" y2="100" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
            <line x1="100" y1="0" x2="100" y2="200" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
        </svg>

        {# Marqueurs en croix — éléments d'ambiance géométrique #}
        <svg style="position:absolute;top:12%;left:6%;opacity:0.18" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="9" y1="0" x2="9" y2="18" stroke="var(--color-muted)" stroke-width="1"/>
            <line x1="0" y1="9" x2="18" y2="9" stroke="var(--color-muted)" stroke-width="1"/>
        </svg>
        <svg style="position:absolute;bottom:18%;right:14%;opacity:0.14" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="9" y1="0" x2="9" y2="18" stroke="var(--color-muted)" stroke-width="1"/>
            <line x1="0" y1="9" x2="18" y2="9" stroke="var(--color-muted)" stroke-width="1"/>
        </svg>
        <svg style="position:absolute;top:55%;left:3%;opacity:0.1" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <rect x="0" y="0" width="12" height="12" stroke="var(--color-primary)" stroke-width="1"/>
        </svg>
    </div>

    <div class="relative max-w-3xl mx-auto text-center" style="z-index:1">

        {# Tagline — texte d'accroche court au-dessus du titre principal #}
        <p style="font-family:var(--font-display);font-size:0.75rem;font-weight:700;
                  text-transform:uppercase;letter-spacing:0.14em;color:var(--color-primary);
                  margin-bottom:1.75rem;
                  animation:fadeIn 0.4s ease both">
            — {{ 'home.tagline'|trans }}
        </p>

        {#
            h1 avec animation CSS (fadeUp).
            opacity:0 en inline + fill-mode:both évite le flash avant l'animation.
            id="hero-heading" est référencé par aria-labelledby sur la <section>.
        #}
        <h1 id="hero-heading"
            style="font-family:var(--font-display);
                   font-size:clamp(2.5rem,9vw,5.75rem);
                   font-weight:800;
                   line-height:1.0;
                   letter-spacing:-0.04em;
                   color:var(--color-text);
                   margin-bottom:0;
                   animation:fadeUp 0.5s 0.1s ease both;
                   opacity:0">
            {{ 'home.headline'|trans }}
        </h1>

        {# Trait décoratif — séparateur éditorial entre titre et sous-titre #}
        <div class="hero-rule" style="animation:fadeIn 0.4s 0.25s ease both;opacity:0"></div>

        <p style="font-size:clamp(0.9375rem,2.5vw,1.0625rem);
                  color:var(--color-muted);
                  line-height:1.75;
                  max-width:30rem;
                  margin:0 auto 2.5rem;
                  animation:fadeUp 0.5s 0.2s ease both;
                  opacity:0">
            {{ 'home.subtitle'|trans }}
        </p>

        {# CTA adaptatif — colonne sur mobile, ligne à partir de 480px (CSS .cta-group) #}
        <div class="cta-group" style="animation:fadeUp 0.5s 0.3s ease both;opacity:0">
            {% if app.user %}
                {# Utilisateur connecté — message personnalisé, pas de lien vers register #}
                <a href="#" class="btn-primary" style="font-size:1rem">
                    {{ 'home.cta_logged'|trans({ name: app.user.name ?? app.user.email }) }}
                </a>
            {% else %}
                <a href="{{ path('app_register') }}" class="btn-primary" style="font-size:1rem">
                    {{ 'home.cta_register'|trans }}
                </a>
                <a href="{{ path('app_login') }}" class="btn-ghost" style="font-size:1rem">
                    {{ 'home.cta_login'|trans }}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            {% endif %}
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════════════ FEATURES #}
{#
    Grille flush — jointures de 1px entre les cartes = effet grille imprimerie.
    h2 sr-only : titre de section pour les lecteurs d'écran (hiérarchie h1>h2 cohérente),
    masqué visuellement car la grille de cartes est auto-explicite.
#}
<section class="features-section" aria-labelledby="features-heading">
    <h2 id="features-heading" class="sr-only">{{ 'home.features_title'|trans }}</h2>

    <div class="features-grid">

        {# Carte 01 — Authentification #}
        <article class="feature-card" style="animation:fadeUp 0.5s 0.1s ease both;opacity:0">
            <span class="feature-num" aria-hidden="true">01</span>
            <h3 style="font-family:var(--font-display);font-size:1.0625rem;font-weight:700;
                       color:var(--color-text);margin-bottom:0.625rem;line-height:1.3">
                {{ 'home.feature_auth_title'|trans }}
            </h3>
            <p style="font-size:0.9375rem;color:var(--color-muted);line-height:1.7;margin:0">
                {{ 'home.feature_auth_desc'|trans }}
            </p>
        </article>

        {# Carte 02 — i18n #}
        <article class="feature-card" style="animation:fadeUp 0.5s 0.2s ease both;opacity:0">
            <span class="feature-num" aria-hidden="true">02</span>
            <h3 style="font-family:var(--font-display);font-size:1.0625rem;font-weight:700;
                       color:var(--color-text);margin-bottom:0.625rem;line-height:1.3">
                {{ 'home.feature_i18n_title'|trans }}
            </h3>
            <p style="font-size:0.9375rem;color:var(--color-muted);line-height:1.7;margin:0">
                {{ 'home.feature_i18n_desc'|trans }}
            </p>
        </article>

        {# Carte 03 — Sécurité #}
        <article class="feature-card" style="animation:fadeUp 0.5s 0.3s ease both;opacity:0">
            <span class="feature-num" aria-hidden="true">03</span>
            <h3 style="font-family:var(--font-display);font-size:1.0625rem;font-weight:700;
                       color:var(--color-text);margin-bottom:0.625rem;line-height:1.3">
                {{ 'home.feature_security_title'|trans }}
            </h3>
            <p style="font-size:0.9375rem;color:var(--color-muted);line-height:1.7;margin:0">
                {{ 'home.feature_security_desc'|trans }}
            </p>
        </article>
    </div>
</section>

{# JSON-LD Schema.org WebSite — aide les moteurs de recherche à comprendre le site #}
{# escape('js') protège contre l'injection si les traductions contiennent des guillemets #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ 'app.name'|trans|escape('js') }}",
    "description": "{{ 'app.description'|trans|escape('js') }}",
    "url": "{{ app.request.schemeAndHttpHost }}"
}
</script>
{% endblock %}
