{#
    Étape 2 du flux de réinitialisation — saisie du nouveau mot de passe.

    Ce template est accessible uniquement via un token valide dans l'URL (/reset-password/{token}).
    Le contrôleur PasswordResetController::reset() valide le token et son expiration (1h)
    avant de rendre ce template. Un token invalide ou expiré redirige vers l'étape 1.

    Formulaire (ResetPasswordFormType) :
      - Identique au formulaire d'inscription pour la partie mot de passe.
      - RepeatedType : deux champs (first + second) pour confirmation.
      - Contraintes CNIL : 12 caractères min, majuscule, minuscule, chiffre.
      - Vérification HIBP effectuée côté serveur après validation des contraintes.

    Indicateur de force (.pw-requirements) :
      Même mécanisme que sur la page d'inscription — app.js surveille l'attribut
      data-strength-input sur le premier champ pour mettre à jour les indicateurs.
#}
{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset_title'|trans }} — {{ 'app.name'|trans }}{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}

{% block body %}
<div class="auth-page">

    {# Décoration géométrique — aria-hidden car purement décoratif #}
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden">
        <div style="position:absolute;inset:0;
                    background-image:linear-gradient(var(--color-border) 1px,transparent 1px),
                                     linear-gradient(90deg,var(--color-border) 1px,transparent 1px);
                    background-size:48px 48px;
                    opacity:0.45;
                    mask-image:radial-gradient(ellipse 70% 80% at 50% 40%,black 10%,transparent 100%)"></div>
    </div>

    <div class="auth-card">

        <div style="margin-bottom:2rem">
            <h1 style="font-family:var(--font-display);font-size:1.75rem;font-weight:800;
                       color:var(--color-text);margin:0 0 0;letter-spacing:-0.03em">
                {{ 'auth.reset_title'|trans }}
            </h1>
            {# Trait décoratif sous le titre #}
            <div style="width:2rem;height:2px;background:var(--color-primary);margin-top:0.875rem"></div>
        </div>

        <div class="card-gradient">
            {# novalidate : la validation HTML5 native est désactivée — Symfony valide côté serveur #}
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                {# Premier champ (mot de passe) avec indicateur de force #}
                <div style="margin-bottom:0.75rem">
                    {{ form_label(form.plainPassword.first, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.plainPassword.first, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.plainPassword.first) }}

                    {#
                        Indicateur de force — mis à jour en temps réel par app.js.
                        aria-live="polite" annonce les changements aux lecteurs d'écran.
                    #}
                    <ul class="pw-requirements" aria-live="polite"
                        aria-label="{{ 'form.pw_strength_title'|trans }}">
                        <li data-req="length">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_length'|trans }}
                        </li>
                        <li data-req="lower">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_lower'|trans }}
                        </li>
                        <li data-req="upper">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_upper'|trans }}
                        </li>
                        <li data-req="digit">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_digit'|trans }}
                        </li>
                    </ul>
                </div>

                {# Champ de confirmation — erreurs de non-correspondance sur form.plainPassword (pas .second) #}
                <div style="margin-bottom:1.625rem">
                    {{ form_label(form.plainPassword.second, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.plainPassword.second, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.plainPassword) }}
                </div>

                <button type="submit" class="btn-primary"
                        style="width:100%;padding:0.875rem;font-size:0.9375rem;justify-content:center">
                    {{ 'auth.reset_submit'|trans }}
                </button>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
