{#
    Page d'inscription avec formulaire email/mot de passe et boutons OAuth.

    Formulaire Symfony (RegistrationFormType) :
      - form_start avec novalidate : la validation HTML5 native est désactivée pour
        laisser Symfony afficher ses propres messages d'erreur traduits.
      - plainPassword est un RepeatedType : deux champs générés, first et second.
        Les erreurs de non-correspondance sont affichées via form_errors(form.plainPassword)
        (sur le type parent, pas sur .first ou .second individuellement).

    Indicateur de force du mot de passe (.pw-requirements) :
      - Chaque <li data-req="..."> est mis à jour en temps réel par app.js
        qui lit l'attribut data-strength-input sur le premier champ.
      - aria-live="polite" annonce les changements aux lecteurs d'écran sans interruption.
      - Classes CSS .ok/.fail ajoutées dynamiquement ; .req-icon affiche ✓ ou ✗.

    Flashes 'error' :
      Affichés au-dessus du formulaire pour les erreurs générales (rate limiting).
      Les erreurs de validation Symfony sont affichées inline via form_errors().
#}
{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register_title'|trans }} — {{ 'app.name'|trans }}{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}

{% block body %}
<div class="auth-page">

    {# Décoration géométrique — aria-hidden car purement décoratif #}
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden">
        <div style="position:absolute;inset:0;
                    background-image:linear-gradient(var(--color-border) 1px,transparent 1px),
                                     linear-gradient(90deg,var(--color-border) 1px,transparent 1px);
                    background-size:48px 48px;
                    opacity:0.45;
                    mask-image:radial-gradient(ellipse 70% 80% at 50% 40%,black 10%,transparent 100%)"></div>
    </div>

    <div class="auth-card">

        <div style="margin-bottom:2rem">
            <a href="{{ path('app_home') }}"
               style="font-family:var(--font-display);font-size:0.6875rem;font-weight:700;
                      text-transform:uppercase;letter-spacing:0.12em;
                      color:var(--color-primary);text-decoration:none;
                      display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1.75rem">
                <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                    <path d="M8 5H2M5 2L2 5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                {{ 'app.name'|trans }}
            </a>
            <h1 style="font-family:var(--font-display);font-size:1.75rem;font-weight:800;
                       color:var(--color-text);margin:0 0 0.375rem;letter-spacing:-0.03em">
                {{ 'auth.register_title'|trans }}
            </h1>
            <p style="font-size:0.9rem;color:var(--color-muted)">
                {{ 'auth.already_account'|trans }}
                <a href="{{ path('app_login') }}"
                   style="color:var(--color-text);font-weight:600;text-decoration:none;
                          border-bottom:1px solid var(--color-primary)">
                    {{ 'auth.login_link'|trans }}
                </a>
            </p>
        </div>

        <div class="card-gradient">
            {# novalidate : désactive la validation HTML5 native — Symfony gère côté serveur #}
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                {# Erreurs générales (rate limiting, HIBP…) transmises via addFlash('error') #}
                {% for message in app.flashes('error') %}
                    <div class="alert-error" style="margin-bottom:1.25rem" role="alert">{{ message }}</div>
                {% endfor %}

                <div style="margin-bottom:1.25rem">
                    {{ form_label(form.name, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.name, {attr: {class: 'form-input', autocomplete: 'name'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div style="margin-bottom:1.25rem">
                    {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.email, {attr: {class: 'form-input', autocomplete: 'email'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                {# Premier champ du RepeatedType — porte l'attribut data-strength-input pour app.js #}
                <div style="margin-bottom:0.75rem">
                    {{ form_label(form.plainPassword.first, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.plainPassword.first, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.plainPassword.first) }}

                    {#
                        Indicateur de force du mot de passe — mis à jour en temps réel par app.js.
                        data-req correspond aux clés vérifiées dans le JS : length, lower, upper, digit.
                        aria-live="polite" annonce les changements d'état aux lecteurs d'écran.
                        req-icon est un span CSS-only (✓/✗) géré par les classes .ok et .fail.
                    #}
                    <ul class="pw-requirements" aria-live="polite"
                        aria-label="{{ 'form.pw_strength_title'|trans }}">
                        <li data-req="length">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_length'|trans }}
                        </li>
                        <li data-req="lower">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_lower'|trans }}
                        </li>
                        <li data-req="upper">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_upper'|trans }}
                        </li>
                        <li data-req="digit">
                            <span class="req-icon" aria-hidden="true"></span>
                            {{ 'form.pw_req_digit'|trans }}
                        </li>
                    </ul>
                </div>

                {#
                    Deuxième champ du RepeatedType (confirmation).
                    Les erreurs de non-correspondance sont sur le type parent form.plainPassword
                    (pas sur .second), d'où form_errors(form.plainPassword) et non form_errors(form.plainPassword.second).
                #}
                <div style="margin-bottom:1.25rem">
                    {{ form_label(form.plainPassword.second, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(form.plainPassword.second, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.plainPassword) }}
                </div>

                {# Case CGU — agreeTerms est une CheckboxType dans RegistrationFormType #}
                <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:1.625rem">
                    {{ form_widget(form.agreeTerms, {attr: {
                        style: 'width:1rem;height:1rem;margin-top:0.125rem;accent-color:var(--color-primary);cursor:pointer;flex-shrink:0'
                    }}) }}
                    <div>
                        {{ form_label(form.agreeTerms, null, {label_attr: {
                            class: 'form-label',
                            style: 'margin:0;font-weight:400;cursor:pointer;text-transform:none;letter-spacing:normal'
                        }}) }}
                        {{ form_errors(form.agreeTerms) }}
                    </div>
                </div>

                <button type="submit" class="btn-primary"
                        style="width:100%;padding:0.875rem;font-size:0.9375rem;justify-content:center">
                    {{ 'auth.register_submit'|trans }}
                </button>

            {{ form_end(form) }}

            <div class="divider" style="margin:1.5rem 0">
                <span class="divider-text">{{ 'auth.or_continue'|trans }}</span>
            </div>

            {# Inscription OAuth — crée ou lie un compte via le flux Authorization Code #}
            <div style="display:flex;flex-direction:column;gap:0.75rem">
                <a href="{{ path('connect_google') }}" class="btn-oauth" aria-label="{{ 'auth.register_google'|trans }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    {{ 'auth.register_google'|trans }}
                </a>

                <a href="{{ path('connect_discord') }}" class="btn-oauth" aria-label="{{ 'auth.register_discord'|trans }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#5865F2" aria-hidden="true">
                        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                    </svg>
                    {{ 'auth.register_discord'|trans }}
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
