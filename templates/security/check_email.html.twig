{#
    Page de confirmation d'envoi de l'e-mail de vérification.

    Contexte :
      L'utilisateur vient de s'inscrire ou de demander un renvoi. L'adresse e-mail
      à afficher est lue depuis la session (clé '_verification_email' définie dans
      SecurityController). Si la session ne contient pas cet e-mail (accès direct à l'URL),
      SecurityController::checkEmail() redirige vers /login avant même d'afficher ce template.

    Formulaire de renvoi :
      Protégé par un token CSRF (id : 'resend_verification').
      L'e-mail est passé en champ caché plutôt qu'en paramètre GET pour éviter
      son exposition dans les logs de serveur et le referrer header.
      SecurityController::resendVerification() traite la requête silencieusement
      (même réponse qu'un compte inexistant — anti-énumération).
#}
{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.check_email_title'|trans }} — {{ 'app.name'|trans }}{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}

{% block body %}
<div class="auth-page" style="text-align:center">

    {# Décoration géométrique — aria-hidden car purement décoratif #}
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;overflow:hidden">
        <div style="position:absolute;inset:0;
                    background-image:linear-gradient(var(--color-border) 1px,transparent 1px),
                                     linear-gradient(90deg,var(--color-border) 1px,transparent 1px);
                    background-size:48px 48px;
                    opacity:0.4;
                    mask-image:radial-gradient(ellipse 70% 80% at 50% 40%,black 10%,transparent 100%)"></div>
    </div>

    <div class="auth-card">

        {# Icône enveloppe — carré géométrique avec bordure couleur succès #}
        <div style="width:56px;height:56px;border:1.5px solid var(--color-success);
                    border-radius:0.375rem;
                    display:flex;align-items:center;justify-content:center;margin:0 auto 2rem">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
            </svg>
        </div>

        <h1 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;
                   color:var(--color-text);margin:0 0 1rem;letter-spacing:-0.025em">
            {{ 'auth.check_email_title'|trans }}
        </h1>

        <p style="color:var(--color-muted);font-size:0.9375rem;line-height:1.65;margin:0 0 0.375rem">
            {{ 'auth.check_email_desc'|trans }}
        </p>
        {# L'adresse e-mail est affichée en évidence pour que l'utilisateur sache où chercher #}
        <p style="color:var(--color-text);font-weight:600;font-size:0.9375rem;margin:0 0 1.5rem;
                  font-family:var(--font-display)">
            {{ email }}
        </p>
        <p style="color:var(--color-muted);font-size:0.875rem;margin:0 0 2.5rem;line-height:1.6">
            {{ 'auth.check_email_spam'|trans }}
        </p>

        {#
            Formulaire de renvoi — CSRF requis.
            L'e-mail en champ caché évite de l'exposer dans l'URL (logs, referrer).
            Traitement silencieux côté serveur (anti-énumération de comptes).
        #}
        <form method="post" action="{{ path('app_resend_verification') }}">
            <input type="hidden" name="email" value="{{ email }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">
            <button type="submit" class="btn-ghost" style="width:100%;justify-content:center">
                {{ 'auth.resend_verification'|trans }}
            </button>
        </form>

        <p style="margin-top:1.5rem">
            <a href="{{ path('app_login') }}"
               style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;
                      display:inline-flex;align-items:center;gap:0.375rem">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M19 12H5M12 5l-7 7 7 7"/>
                </svg>
                {{ 'auth.back_to_login'|trans }}
            </a>
        </p>
    </div>
</div>
{% endblock %}
